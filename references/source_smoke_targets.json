      "expect_any": ["财富号", "caifuhao", "东方财富"],
      "min_bytes": 2000
    },
    {
      "name": "10jqka homepage",
      "url": "https://www.10jqka.com.cn/",
      "expect_any": ["同花顺", "10jqka"],
      "min_bytes": 2000
    },
    {
      "name": "Xueqiu homepage",
      "url": "https://xueqiu.com/",
      "expect_any": ["雪球", "xueqiu", "aliyun_waf", "_waf_"],
